{
  "$schema": "./config.schema.json",
  "figureCaption": {
    "enabled": true,
    "format": "图 {n}",
    "separator": "："
  },
  "tableCaption": {
    "enabled": true,
    "format": "表 {n}",
    "separator": ""
  },
  "normalizeHeadings": {
    "enabled": true
  },
  "numberHeadings": {
    "enabled": true,
    "detectExisting": true,
    "useBuiltinRules": true
  },
  "renderMermaid": {
    "enabled": true,
    "outputDir": "{file_name}_assets",
    "theme": "tokyo-night-light",
    "density": 200,
    "fileName": "mermaid_{n}"
  },
  "title": {
    "enabled": true,
    "strategy": "first-h1"
  }
}
