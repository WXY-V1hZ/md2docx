{
  "name": "@v1hz/md2docx",
  "version": "1.0.0",
  "description": "基于 pandoc 的 Markdown 转 Word (docx) 工具，自动处理标题、编号、Mermaid 图表等",
  "keywords": [
    "converter",
    "docx",
    "markdown",
    "mermaid",
    "pandoc",
    "word"
  ],
  "homepage": "https://github.com/WXY-V1hZ/md2docx#readme",
  "bugs": {
    "url": "https://github.com/WXY-V1hZ/md2docx/issues"
  },
  "license": "MIT",
  "author": "WXY-V1hZ",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/WXY-V1hZ/md2docx.git"
  },
  "bin": {
    "md2docx": "src/index.ts"
  },
  "files": [
    "src",
    "config/config.json",
    "config/config.schema.json",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "module": "src/index.ts",
  "scripts": {
    "cli": "bun run src/index.ts",
    "test": "bun test",
    "check": "bun tsc --noEmit && bun run oxlint && bun run oxfmt"
  },
  "dependencies": {
    "@xmldom/xmldom": "^0.9.10",
    "beautiful-mermaid": "^1.1.3",
    "docx": "^9.7.1",
    "pizzip": "^3.2.0",
    "remark-frontmatter": "^5.0.0",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "remark-stringify": "^11.0.0",
    "sharp": "^0.35.3",
    "unified": "^11.0.5",
    "xpath": "^0.0.34"
  },
  "devDependencies": {
    "oxfmt": "^0.58.0",
    "oxlint": "^1.73.0"
  },
  "engines": {
    "bun": ">=1.3"
  }
}
