{
  "$schema": "https://raw.githubusercontent.com/WXY-V1hZ/md2docx/main/config/config.schema.json",
  "figureCaption": {
    "enabled": true,
    "format": "图 {n}",
    "separator": "："
  },
  "tableCaption": {
    "enabled": true,
    "format": "表 {n}",
    "separator": " "
  },
  "normalizeHeadings": {
    "enabled": true
  },
  "numberHeadings": {
    "enabled": true,
    "detectExisting": true,
    "useBuiltinRules": true
  },
  "renderMermaid": {
    "enabled": true,
    "theme": "tokyo-night-light",
    "density": 200
  },
  "imageSize": {
    "enabled": true,
    "maxWidthCm": 12,
    "maxHeightCm": 12
  },
  "detectTitle": {
    "enabled": true,
    "strategy": "first-h1"
  },
  "removeThematicBreaks": {
    "enabled": true
  }
}
