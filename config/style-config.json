{
  "$schema": "https://raw.githubusercontent.com/WXY-V1hZ/md2docx/main/config/style-config.schema.json",
  "schemaVersion": 1,
  "options": {
    "body": {
      "firstLineIndent": true,
      "lineSpacing": 1.5
    },
    "headings": {
      "1": {
        "startOnNewPage": false,
        "alignment": "left",
        "bold": true
      },
      "2": {
        "bold": true
      },
      "3": {
        "bold": true
      },
      "4": {
        "bold": true,
        "italic": false
      },
      "5": {
        "bold": true,
        "italic": false
      },
      "6": {
        "bold": true,
        "italic": false
      }
    },
    "inlineCode": {
      "background": true
    },
    "codeBlock": {
      "border": true
    }
  }
}
