{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/WXY-V1hZ/md2docx/main/config/style-config.schema.json",
  "title": "md2docx 语义化样式配置",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion"],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "schemaVersion": {
      "const": 1
    },
    "options": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "body": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "firstLineIndent": {
              "type": "boolean",
              "description": "正文是否使用预设的首行缩进"
            },
            "lineSpacing": {
              "type": "number",
              "exclusiveMinimum": 0,
              "description": "正文行距倍数，如 1.5 表示 1.5 倍行距"
            }
          }
        },
        "headings": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "1": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "startOnNewPage": {
                  "type": "boolean",
                  "description": "一级标题是否另起一页"
                },
                "alignment": {
                  "type": "string",
                  "enum": ["left", "center"],
                  "description": "一级标题左对齐或居中"
                },
                "bold": {
                  "type": "boolean",
                  "description": "一级标题是否加粗"
                }
              }
            },
            "2": {
              "$ref": "#/$defs/headingBold"
            },
            "3": {
              "$ref": "#/$defs/headingBold"
            },
            "4": {
              "$ref": "#/$defs/headingBoldItalic"
            },
            "5": {
              "$ref": "#/$defs/headingBoldItalic"
            },
            "6": {
              "$ref": "#/$defs/headingBoldItalic"
            }
          }
        },
        "inlineCode": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "background": {
              "type": "boolean",
              "description": "行内代码是否使用预设背景"
            }
          }
        },
        "codeBlock": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "border": {
              "type": "boolean",
              "description": "代码块是否使用预设外框"
            }
          }
        }
      }
    }
  },
  "$defs": {
    "headingBold": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "bold": {
          "type": "boolean",
          "description": "标题是否加粗"
        }
      }
    },
    "headingBoldItalic": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "bold": {
          "type": "boolean",
          "description": "标题是否加粗"
        },
        "italic": {
          "type": "boolean",
          "description": "标题是否斜体"
        }
      }
    }
  }
}
