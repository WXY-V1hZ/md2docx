{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://raw.githubusercontent.com/WXY-V1hZ/md2docx/main/config/config.schema.json",
  "title": "md2docx 配置",
  "description": "md2docx 默认设置",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "figureCaption": {
      "description": "图片编号",
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": {
          "description": "自动为图片编号",
          "type": "boolean",
          "default": true
        },
        "format": {
          "description": "编号格式，{n} 代表序号",
          "type": "string",
          "default": "图 {n}"
        },
        "separator": {
          "description": "编号与图片标题之间的分隔符",
          "type": "string",
          "default": "："
        }
      },
      "required": ["enabled", "format", "separator"]
    },
    "tableCaption": {
      "description": "表格编号",
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": {
          "description": "自动为表格编号",
          "type": "boolean",
          "default": true
        },
        "format": {
          "description": "编号格式，{n} 代表序号",
          "type": "string",
          "default": "表 {n}"
        },
        "separator": {
          "description": "编号与表格标题之间的分隔符",
          "type": "string",
          "default": " "
        }
      },
      "required": ["enabled", "format", "separator"]
    },
    "normalizeHeadings": {
      "description": "标题层级",
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": {
          "description": "自动修正标题层级（标题编号开启时无法关闭）",
          "type": "boolean",
          "default": true
        }
      },
      "required": ["enabled"]
    },
    "numberHeadings": {
      "description": "标题编号",
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": {
          "description": "自动为标题添加层级编号（同时修正标题层级）",
          "type": "boolean",
          "default": true
        },
        "detectExisting": {
          "description": "重新编号前移除已有编号",
          "type": "boolean",
          "default": true
        },
        "existingPattern": {
          "description": "识别已有编号的正则表达式（可选）",
          "type": "string",
          "default": ""
        },
        "useBuiltinRules": {
          "description": "识别常见的中文和数字编号",
          "type": "boolean",
          "default": true
        }
      },
      "required": ["enabled", "detectExisting"]
    },
    "renderMermaid": {
      "description": "Mermaid 图表",
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": {
          "description": "将 Mermaid 代码块转换为图片",
          "type": "boolean",
          "default": true
        },
        "theme": {
          "description": "图表主题",
          "type": "string",
          "default": "tokyo-night-light"
        },
        "density": {
          "description": "图片清晰度（DPI）",
          "type": "integer",
          "minimum": 72,
          "default": 200
        }
      },
      "required": ["enabled", "theme", "density"]
    },
    "detectTitle": {
      "description": "文档标题",
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": {
          "description": "自动设置文档标题",
          "type": "boolean",
          "default": true
        },
        "strategy": {
          "description": "标题来源",
          "type": "string",
          "enum": ["first-h1", "single-h1", "filename", "none"],
          "enumDescriptions": {
            "first-h1": "开头的一级标题",
            "single-h1": "文档中唯一的一级标题",
            "filename": "文件名",
            "none": "不设置"
          },
          "default": "first-h1"
        }
      },
      "required": ["enabled", "strategy"]
    }
  },
  "required": [
    "figureCaption",
    "tableCaption",
    "normalizeHeadings",
    "numberHeadings",
    "renderMermaid",
    "detectTitle"
  ]
}
